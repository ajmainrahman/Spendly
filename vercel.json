{
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/budget-tracker run build",
  "outputDirectory": "artifacts/budget-tracker/dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
